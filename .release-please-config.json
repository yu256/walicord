{
  "plugins": [
    "cargo-workspace"
  ],
  "packages": {
    "walicord": {
      "release-type": "rust",
      "bump-minor-pre-release": "beta",
      "bump-patch-pre-release": "alpha",
      "extra-files": [],
      "include-paths": [
        "walicord-parser",
        "walicord-domain",
        "walicord-application",
        "walicord-infrastructure",
        "walicord-presentation",
        "walicord-i18n",
        "walicord-transfer-construction",
        "docs"
      ]
    }
  }
}
